rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ── Photos: public read, authenticated write ─────────────────────────────
    // Used for staff and student profile photos. Stored under
    //   photos/staff/<staffId>.<ext>
    //   photos/students/<studentId>.<ext>
    match /photos/{type}/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Documents: private, only accessible via server-signed URLs ───────────
    // Used for lesson plans, schemes, and assignments. Stored under
    //   documents/lesson-plans/<planId>/<filename>
    //   documents/schemes/<schemeId>/<filename>
    //   documents/assignments/<assignmentId>/<filename>
    match /documents/{type}/{file=**} {
      allow read: if false; // signed-URL only via firebase-admin
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }

    // Default: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
