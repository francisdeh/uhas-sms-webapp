{
  "name": "uhas-sms-webapp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "generate:api-types": "openapi-typescript http://localhost:8000/openapi.json -o src/types/api.d.ts",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx scripts/migrate.ts",
    "db:seed": "npx tsx scripts/seed-db.ts --idempotent",
    "db:seed:reset": "npx tsx scripts/seed-db.ts --reset",
    "db:seed:prod": "npx tsx scripts/seed-db.ts --idempotent --no-demo",
    "db:test:setup": "npx tsx tests/setup-test-db.ts",
    "db:e2e:setup": "dotenv -e .env.e2e -- npx tsx tests/e2e/setup-db.ts",
    "test": "dotenv -e .env.test -- vitest run",
    "test:watch": "dotenv -e .env.test -- vitest",
    "e2e:build": "dotenv -e .env.e2e -- next build",
    "e2e": "dotenv -e .env.e2e -- playwright test",
    "e2e:ui": "dotenv -e .env.e2e -- playwright test --ui",
    "e2e:headed": "dotenv -e .env.e2e -- playwright test --headed",
    "seed:supabase": "dotenv -e .env.local -- npx tsx scripts/seed-supabase-users.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@sentry/nextjs": "^10.62.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-table": "^8.21.3",
    "@types/pg": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "drizzle-orm": "^0.45.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.400.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "nodemailer": "^8.0.7",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.74.0",
    "recharts": "^2.12.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.0.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8",
    "shadcn": "^4.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  }
}
