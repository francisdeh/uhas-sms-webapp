# ─── Database ─────────────────────────────────────────────────────────────────
# Local Docker: docker compose up -d
DATABASE_URL=postgresql://uhas:uhas_dev_secret@localhost:5436/uhas_sms
# Production (Neon) — replace with your Neon connection string:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/uhas_sms?sslmode=require

# Optional override. Auto-detected as 'neon-http' for *.neon.tech URLs, 'pg' otherwise.
# DB_DRIVER=pg

# ─── Outbound email (SMTP) ────────────────────────────────────────────────────
# Used by src/lib/email.ts. If SMTP_HOST/USER/PASS are unset, the app logs
# emails to the console instead of sending — safe for dev + CI.
#
# For Gmail SMTP:
#   1. Enable 2FA on the account (Account → Security)
#   2. Create an App Password (Account → Security → App passwords)
#   3. Put the 16-char App Password (not the account password) in SMTP_PASS
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=
# EMAIL_FROM=UHAS SMS <you@gmail.com>
#
# Dev safety net: route every outbound email here instead of the real
# recipient. Only active when NODE_ENV !== "production".
# EMAIL_DEV_REDIRECT=

# Used in email links so recipients land on the right host. Defaults to
# http://localhost:3000 in dev; set this to your Railway URL in prod.
# APP_URL=https://uhas-sms.up.railway.app

# ─── FastAPI backend (Phase 0 PR #4 onward) ───────────────────────────────────
# The Next.js client + Server Components call FastAPI through this URL.
# Locally: http://localhost:8000 (boot via `cd apps/api && uv run uvicorn …`).
# Prod:    the Railway api service URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Supabase Auth (Phase 1) ──────────────────────────────────────────────────
# The Next.js client signs users in via Supabase Auth and the proxy
# reads the resulting session from cookies. Both keys are required for
# login to work — get them from `supabase status` (local) or your
# Supabase project's API settings (prod).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Service role key — server-side ONLY, never expose to the browser.
# Bypasses RLS entirely; only the seed script + admin user-creation
# Server Actions should use it. Get it from `supabase status`.
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
# All Sentry behaviour is a silent no-op when NEXT_PUBLIC_SENTRY_DSN is unset,
# so leaving these blank locally is fine. Set on Railway when the Sentry
# project exists.
#
# Create at sentry.io → New Project → Next.js. Copy the DSN.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_TRACES_SAMPLE_RATE=0.2
#
# Source-map upload at build time (Sentry CLI). Generate at Sentry →
# User Settings → Auth Tokens, with `project:releases` scope. Only set
# in CI / Railway; not needed locally.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=uhas-sms
# SENTRY_PROJECT=uhas-sms-web
