# E2E database — separate from dev (`uhas_sms`) and Vitest (`uhas_sms_test`).
DATABASE_URL=postgresql://uhas:uhas_dev_secret@localhost:5436/uhas_sms_e2e
DB_DRIVER=pg
NODE_ENV=test

# Supabase Auth — points at the local CLI stack. The E2E setup must run
# `supabase start` + `npm run seed:supabase` before Playwright kicks off.
# Keys are the well-known local-dev defaults (same as in .env.local).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# E2E uses port 3100 to avoid clashing with `npm run dev` on 3000.
E2E_BASE_URL=http://localhost:3100
