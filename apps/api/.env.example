# Copy to .env (gitignored) for local development.
#
# Every value here has a sensible default in app/core/config.py, so a
# missing .env still boots — these overrides only matter when you want
# to point at something other than the local Supabase stack.

# ── Identity ──────────────────────────────────────────────────────────────────
ENV=dev

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated. Default is http://localhost:3000 (the Next.js dev server).
# In prod, add the Railway web service URL.
# CORS_ALLOW_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Local Supabase Postgres (from `supabase start`):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# Local Docker Postgres (the one apps/web uses today):
# DATABASE_URL=postgresql+asyncpg://uhas:uhas_dev_secret@localhost:5436/uhas_sms

# Production (Supabase project URL):
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@<project>.pooler.supabase.com:5432/postgres

# Log every SQL statement. Useful in dev; never in prod.
# DATABASE_ECHO=false

# ── Observability ─────────────────────────────────────────────────────────────
# Both SDKs are silent no-ops when unset. Set on Railway when the
# corresponding accounts exist.
#
# Sentry — create a project at sentry.io, copy the FastAPI DSN:
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_TRACES_SAMPLE_RATE=0.2
#
# Logfire — create a workspace at logfire.pydantic.dev, copy the write token:
# LOGFIRE_TOKEN=lgf_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Defaults below match the local Supabase CLI stack (`supabase start`),
# so the API works locally with zero config. In prod, override with the
# project's URL + secrets from Supabase Dashboard → Project Settings → API.
#
# SUPABASE_JWT_SECRET is the HS256 key used to verify inbound JWTs —
# this MUST match what Supabase Auth signs tokens with. Find it in
# Project Settings → API → JWT Secret.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# SUPABASE_ANON_KEY=<from supabase start>          # not used server-side
# SUPABASE_SERVICE_ROLE_KEY=<from supabase start>  # for seed script + admin ops

# ── Background jobs (Inngest) ───────────────────────────────────────────────────
# Dev/test/staging all run in Inngest's "dev mode" automatically (see
# app/core/inngest.py) — no credentials needed. Run `uv run inngest-cli dev`
# in its own terminal for the local dev server + inspector UI at
# http://localhost:8288. Only production needs these:
# INNGEST_EVENT_KEY=<from Inngest Cloud dashboard>
# INNGEST_SIGNING_KEY=<from Inngest Cloud dashboard>

# ── Outbound email ───────────────────────────────────────────────────────────────
# Missing config isn't an error — emails are logged instead of sent (see
# app/integrations/email/provider.py). Gmail App Password for dev; swap
# to a transactional provider later without touching any caller.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=<Gmail App Password, not the account password>
# EMAIL_FROM=UHAS SMS <noreply@uhas.edu.gh>
# EMAIL_DEV_REDIRECT=<address to catch all non-prod email>
# APP_URL=http://localhost:3000
