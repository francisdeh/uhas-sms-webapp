# ─── App ──────────────────────────────────────────────────────────────────────
# Set to "true" locally to skip the database and use fixture data instead.
# Must be "false" (or unset) in production.
USE_MOCK_DATA=true

# ─── Firebase (Client SDK — public, safe to expose) ───────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase (Admin SDK — secret, server-side only) ──────────────────────────
# Copy these from Firebase console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key exactly as it appears in the JSON (with literal \n line breaks)
FIREBASE_PRIVATE_KEY=

# ─── Firebase Emulator (local dev only) ───────────────────────────────────────
# Uncomment when running the Firebase Auth Emulator locally (npm run emulator)
# NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# ─── Database ─────────────────────────────────────────────────────────────────
# Local Docker: docker compose up -d
DATABASE_URL=postgresql://uhas:uhas_dev_secret@localhost:5432/uhas_sms
# Production (Neon) — replace with your Neon connection string:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/uhas_sms?sslmode=require
