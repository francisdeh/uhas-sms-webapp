# ─── Dev flags ────────────────────────────────────────────────────────────────
USE_MOCK_DATA=true
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# ─── Firebase (not needed while emulator is active) ───────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Database ─────────────────────────────────────────────────────────────────
# Local Docker (docker compose up -d):
DATABASE_URL=postgresql://uhas:uhas_dev_secret@localhost:5432/uhas_sms
# Production (Neon) — replace with your Neon connection string:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/uhas_sms?sslmode=require
